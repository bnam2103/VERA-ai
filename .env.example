# Copy to `.env` in the project root (same directory as app.py). Restart the API after editing.
# Never commit `.env`.

# --- Supabase (backend + browser anon via GET /api/auth/config) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Public API base URL (optional; served to browser via /api/auth/config) ---
# Set to your Cloudflare Worker or uvicorn public URL, e.g. https://your-worker.workers.dev
VERA_API_BASE_URL=

# --- OpenAI (used by CHAT*.py / reasoning; standard OPENAI_API_KEY env) ---
OPENAI_API_KEY=

# --- Search / weather ---
SERPER_API_KEY=
OPENWEATHER_API_KEY=

# --- BMO Fish TTS (when browser sends client=bmo) ---
FISH_API_KEY=
# FISH_AUDIO_API_KEY=
REFERENCE_ID=
# FISH_REFERENCE_ID=
# BMO_REFERENCE_ID=
# FISH_TTS_MODEL=speech-1.5
# FISH_TTS_LATENCY=balanced

# --- Spotify OAuth ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=
# SPOTIFY_OAUTH_RETURN_URL=https://YOUR_USER.github.io/YOUR_REPO

# --- Session / cookies ---
SESSION_SECRET=
# VERA_SESSION_CROSS_SITE=1

# --- TTS / dev toggles ---
VERA_TTS_SENTENCE_CHUNKS=1
# VERA_DEV_MODE=0

# --- Dev/testing only: session no-cap toggle (disables cap enforcement, not accounting) ---
# WARNING: keep false on public production. When true, frontend shows a testing button.
# VERA_ENABLE_NO_CAP_TOGGLE=false

# --- Optional paths ---
# VERA_SPOTIFY_BEARER_STORE=
